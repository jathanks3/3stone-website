---
// src/pages/pricing.astro
// "Build Your Business Stack" — the conversion page. A business owner
// picks their industry, marks each tool they run as KEEP or REPLACE, and
// watches the honest math: current spend, recommended configuration,
// investment, and a three-outcome ROI that never manufactures savings.
//
// All prices come from the pricing engine (src/pricing/) — nothing here is
// hardcoded. Competitor prices are estimates until verified in the catalog.
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import { brand } from "../config/brand";
import { industries } from "../pricing/data/industries";
import { softwareCatalog } from "../pricing/data/software";
import { productModules } from "../pricing/data/modules";

const title = "Pricing";
const description =
  "Build your business stack: keep the software you love, replace what you don't, and see your estimated investment and savings — honestly calculated.";

function priceLabel(tool: (typeof softwareCatalog)[number]): string {
  const est = tool.verified ? "" : " est.";
  switch (tool.pricingModel) {
    case "flat":
      return `$${tool.estMonthly}/mo${est}`;
    case "per_user":
      return `$${tool.estMonthly}/user/mo${est}`;
    case "per_location":
      return `$${tool.estMonthly}/location/mo${est}`;
    case "transaction":
      return "processing fees only";
  }
}
---

<BaseLayout title={title} description={description}>
  <!-- Section 1 — hero -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">Pricing</span>
      <h1>Build Your Business Stack.</h1>
      <p class="hero-sub">
        Choose what you already use. Choose what you'd like to replace.
        Instantly see your estimated investment and savings.
      </p>
      <Button href="#builder" variant="primary">Start Building Your Stack</Button>
      <p class="hero-note">Takes about a minute. No email required.</p>
    </div>
  </section>

  <!-- Section 2 — industry + business size -->
  <section class="builder-step" id="builder">
    <div class="container">
      <span class="step-label">Step 1</span>
      <h2>What kind of business do you run?</h2>
      <div class="industry-grid" role="group" aria-label="Choose your industry">
        {industries.map((industry) => (
          <button class="industry-chip" data-industry={industry.key} aria-pressed="false">
            {industry.label}
          </button>
        ))}
      </div>

      <div class="size-row">
        <div class="size-field">
          <label for="employees-input">Employees</label>
          <div class="stepper">
            <button type="button" data-step="employees" data-dir="-1" aria-label="Fewer employees">−</button>
            <input id="employees-input" type="number" min="1" max="500" value="10" inputmode="numeric" />
            <button type="button" data-step="employees" data-dir="1" aria-label="More employees">+</button>
          </div>
        </div>
        <div class="size-field">
          <label for="locations-input">Locations</label>
          <div class="stepper">
            <button type="button" data-step="locations" data-dir="-1" aria-label="Fewer locations">−</button>
            <input id="locations-input" type="number" min="1" max="50" value="1" inputmode="numeric" />
            <button type="button" data-step="locations" data-dir="1" aria-label="More locations">+</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 — current software, keep/replace -->
  <section class="builder-step">
    <div class="container">
      <span class="step-label">Step 2</span>
      <h2>Which software do you use today?</h2>
      <p class="step-sub">
        Mark each tool <strong>Keep</strong> or <strong>Replace</strong> — every combination works.
        Keep what you love; 3Stone One connects to it.
      </p>
      <div class="tool-grid">
        {softwareCatalog.map((tool) => (
          <div
            class="tool-card"
            data-tool={tool.key}
            data-replaceable={tool.replacedByModules.length > 0 ? "true" : "false"}
          >
            <div class="tool-head">
              <span class="tool-mark" aria-hidden="true">{tool.name.charAt(0)}</span>
              <div>
                <span class="tool-name">{tool.name}</span>
                <span class="tool-meta">{tool.category} · {priceLabel(tool)}</span>
              </div>
            </div>
            <button class="tool-use" data-action="use">+ I use this</button>
            <div class="tool-controls" hidden>
              <div class="choice-group" role="group" aria-label={`Keep or replace ${tool.name}`}>
                <button class="choice choice-keep" data-action="keep" aria-pressed="false">Keep</button>
                <button
                  class="choice choice-replace"
                  data-action="replace"
                  aria-pressed="false"
                  disabled={tool.replacedByModules.length === 0}
                  title={tool.replacedByModules.length === 0 ? tool.keepNote : undefined}
                >Replace</button>
              </div>
              <button class="tool-remove" data-action="remove" aria-label={`I don't use ${tool.name}`}>×</button>
            </div>
            {tool.keepNote && <p class="keep-note" hidden>{tool.keepNote}</p>}
          </div>
        ))}
      </div>
      <p class="estimate-note">
        Prices marked “est.” are estimates of typical published list pricing — not quotes,
        and not verified against today's vendor pages. Your exact numbers come from a discovery call.
      </p>
    </div>
  </section>

  <!-- Section 4 — current spend -->
  <section class="builder-step" id="spend">
    <div class="container">
      <span class="step-label">Step 3</span>
      <h2>What your current stack costs</h2>
      <div class="stat-row" aria-live="polite">
        <div class="stat-tile">
          <span class="stat-label">Monthly software spend</span>
          <span class="stat-value" id="stat-monthly" data-count>$0</span>
        </div>
        <div class="stat-tile">
          <span class="stat-label">Annual software spend</span>
          <span class="stat-value" id="stat-annual" data-count>$0</span>
        </div>
        <div class="stat-tile">
          <span class="stat-label">Setup costs already paid</span>
          <span class="stat-value" id="stat-implementation" data-count>$0</span>
        </div>
      </div>
      <ul class="spend-lines" id="spend-lines"></ul>
    </div>
  </section>

  <!-- Section 5 — recommended configuration -->
  <section class="builder-step">
    <div class="container">
      <span class="step-label">Step 4</span>
      <h2>Your recommended 3Stone One configuration</h2>
      <div class="module-grid" id="module-grid">
        {productModules.map((module) => (
          <div class="module-card" data-module={module.key}>
            <span class="module-check" aria-hidden="true">✓</span>
            <div>
              <span class="module-name">{module.label}</span>
              <span class="module-blurb">{module.blurb}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 6 — investment -->
  <section class="builder-step" id="investment">
    <div class="container">
      <span class="step-label">Step 5</span>
      <h2>Your estimated investment</h2>
      <div class="stat-row" aria-live="polite">
        <div class="stat-tile stat-accent">
          <span class="stat-label">Est. monthly subscription</span>
          <span class="stat-value" id="stat-subscription" data-count>$0</span>
        </div>
        <div class="stat-tile">
          <span class="stat-label">Est. implementation (one-time)</span>
          <span class="stat-value" id="stat-setup" data-count>$0</span>
        </div>
        <div class="stat-tile">
          <span class="stat-label">Est. first-year investment</span>
          <span class="stat-value" id="stat-firstyear" data-count>$0</span>
        </div>
      </div>
      <p class="estimate-note">
        Calculated live by our pricing engine from your selections — nothing here is a canned number.
        Final pricing is confirmed after a discovery call.
      </p>
    </div>
  </section>

  <!-- Section 7 — comparison -->
  <section class="builder-step">
    <div class="container">
      <h2>Your current stack vs. 3Stone One</h2>
      <div class="compare-wrap">
        <table class="compare-table">
          <thead>
            <tr><th scope="col">Capability</th><th scope="col">Today</th><th scope="col">With 3Stone One</th></tr>
          </thead>
          <tbody id="compare-dynamic"></tbody>
          <tbody>
            <tr><td>Admin view of the business</td><td>Spread across multiple apps</td><td>One dashboard</td></tr>
            <tr><td>Logins</td><td>One per tool</td><td>One, total</td></tr>
            <tr><td>AI</td><td>Optional, per-tool add-ons</td><td>Built in, across every module</td></tr>
            <tr><td>Client experience</td><td>Email threads and PDFs</td><td>A branded client portal</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Section 8 — honest ROI -->
  <section class="builder-step">
    <div class="container">
      <div class="roi-panel" id="roi-panel" aria-live="polite">
        <span class="eyebrow">The honest math</span>
        <h2 id="roi-headline">Pick your industry and tools to see your outcome.</h2>
        <p id="roi-explanation">
          Some businesses save money. Some pay about the same for far more capability.
          Some invest a little more. We show you which one you are — honestly.
        </p>
        <div class="roi-delta" id="roi-delta" hidden>
          <span class="stat-label" id="roi-delta-label">Change in monthly cost</span>
          <span class="stat-value" id="roi-delta-value" data-count>$0</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 9 — discovery call -->
  <section class="builder-step cta-final" id="cta">
    <div class="container cta-inner">
      <h2>Bring these numbers to a discovery call.</h2>
      <p class="step-sub">
        Your industry, team size, keep/replace choices, and estimates travel with the booking —
        so the call starts from your business, not a blank page.
      </p>
      <div class="cta-buttons">
        <a
          id="cta-calendly"
          class="cta-primary"
          href={brand.discoveryCallUrl}
          target="_blank"
          rel="noopener noreferrer"
        >Book a Discovery Call</a>
        <button id="cta-copy" class="cta-secondary" type="button">Copy my summary</button>
      </div>
      <p class="hero-note" id="copy-confirm" hidden>Summary copied — paste it anywhere.</p>
      <noscript>
        <p class="estimate-note">
          The interactive calculator needs JavaScript. Without it, you can still
          <a href={brand.discoveryCallUrl}>book a discovery call</a> and we'll run the numbers together.
        </p>
      </noscript>
    </div>
  </section>

  <!-- Sticky live estimate -->
  <div class="sticky-bar" id="sticky-bar" hidden>
    <span>Your estimate: <strong id="sticky-monthly">$0</strong>/mo</span>
    <a href="#investment">See your plan</a>
  </div>
</BaseLayout>

<script>
  import {
    buildCalendlyUrl,
    buildDiscoverySummary,
    buildQuote,
    computeRoi,
    estimateCurrentSpend,
    formatMoney,
  } from "../pricing/engine";
  import { getIndustry } from "../pricing/data/industries";
  import { getTool } from "../pricing/data/software";
  import { brand } from "../config/brand";
  import type { StackSelection, ToolChoice } from "../pricing/types";

  const STORAGE_KEY = "threestone-stack-builder";

  const selection: StackSelection = {
    industryKey: null,
    employees: 10,
    locations: 1,
    tools: {},
  };

  try {
    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved) Object.assign(selection, JSON.parse(saved));
  } catch {
    /* private mode — live without persistence */
  }

  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const counters = new Map<HTMLElement, number>();

  function setMoney(el: HTMLElement | null, value: number) {
    if (!el) return;
    const from = counters.get(el) ?? 0;
    counters.set(el, value);
    if (reducedMotion || Math.abs(value - from) < 1) {
      el.textContent = formatMoney(value);
      return;
    }
    const start = performance.now();
    const duration = 400;
    function tick(now: number) {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      el!.textContent = formatMoney(Math.round(from + (value - from) * eased));
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function esc(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function render() {
    // Industry chips
    document.querySelectorAll<HTMLButtonElement>(".industry-chip").forEach((chip) => {
      const active = chip.dataset.industry === selection.industryKey;
      chip.classList.toggle("active", active);
      chip.setAttribute("aria-pressed", String(active));
    });

    // Size inputs
    (document.getElementById("employees-input") as HTMLInputElement).value = String(selection.employees);
    (document.getElementById("locations-input") as HTMLInputElement).value = String(selection.locations);

    // Tool cards
    document.querySelectorAll<HTMLElement>(".tool-card").forEach((card) => {
      const key = card.dataset.tool!;
      const choice = selection.tools[key];
      const used = Boolean(choice);
      card.classList.toggle("in-use", used);
      card.classList.toggle("will-replace", choice === "replace");
      (card.querySelector(".tool-use") as HTMLElement).hidden = used;
      (card.querySelector(".tool-controls") as HTMLElement).hidden = !used;
      const keepBtn = card.querySelector(".choice-keep") as HTMLButtonElement;
      const replaceBtn = card.querySelector(".choice-replace") as HTMLButtonElement;
      keepBtn.classList.toggle("active", choice === "keep");
      keepBtn.setAttribute("aria-pressed", String(choice === "keep"));
      replaceBtn.classList.toggle("active", choice === "replace");
      replaceBtn.setAttribute("aria-pressed", String(choice === "replace"));
      const note = card.querySelector(".keep-note") as HTMLElement | null;
      if (note) note.hidden = !used;
    });

    const spend = estimateCurrentSpend(selection);
    const quote = buildQuote(selection);
    const roi = computeRoi(spend, quote);
    const anySelection = Object.keys(selection.tools).length > 0;

    // Current spend
    setMoney(document.getElementById("stat-monthly"), spend.monthly);
    setMoney(document.getElementById("stat-annual"), spend.annual);
    setMoney(document.getElementById("stat-implementation"), spend.implementationPaid);
    const lines = document.getElementById("spend-lines")!;
    lines.innerHTML = spend.lines
      .map((line) => {
        const amount = line.monthly > 0
          ? `${formatMoney(line.monthly)}/mo${line.estimated ? " est." : ""}`
          : (line.transactionNote ?? "—");
        return `<li class="${line.choice === "replace" ? "line-replace" : ""}">
          <span>${esc(line.name)}</span>
          <span class="line-tag">${line.choice === "replace" ? "replacing" : "keeping"}</span>
          <span class="line-amount">${esc(amount)}</span>
        </li>`;
      })
      .join("");

    // Modules
    document.querySelectorAll<HTMLElement>(".module-card").forEach((card) => {
      card.classList.toggle("active", quote.modules.includes(card.dataset.module!));
    });

    // Investment
    setMoney(document.getElementById("stat-subscription"), quote.monthlySubscription);
    setMoney(document.getElementById("stat-setup"), quote.implementationOneTime);
    setMoney(document.getElementById("stat-firstyear"), quote.firstYearInvestment);

    // Comparison rows for replaced tools
    const compare = document.getElementById("compare-dynamic")!;
    compare.innerHTML = spend.lines
      .filter((line) => line.choice === "replace")
      .map((line) => {
        const tool = getTool(line.key);
        const cost = line.monthly > 0 ? `${formatMoney(line.monthly)}/mo est.` : "in use";
        return `<tr>
          <td>${esc(tool?.category ?? line.name)}</td>
          <td>${esc(line.name)} — ${esc(cost)}</td>
          <td class="compare-good">Included</td>
        </tr>`;
      })
      .join("");

    // ROI — only meaningful once tools are selected
    const headline = document.getElementById("roi-headline")!;
    const explanation = document.getElementById("roi-explanation")!;
    const deltaWrap = document.getElementById("roi-delta")!;
    const panel = document.getElementById("roi-panel")!;
    panel.classList.remove("roi-savings", "roi-comparable", "roi-premium");
    if (anySelection) {
      headline.textContent = roi.headline;
      explanation.textContent = roi.explanation;
      deltaWrap.hidden = false;
      const deltaLabel = document.getElementById("roi-delta-label")!;
      deltaLabel.textContent =
        roi.monthlyDelta < 0 ? "Estimated monthly savings" : "Change in monthly cost";
      setMoney(document.getElementById("roi-delta-value"), Math.abs(Math.round(roi.monthlyDelta)));
      panel.classList.add(`roi-${roi.kind}`);
    } else {
      deltaWrap.hidden = true;
    }

    // Discovery-call handoff
    const summary = buildDiscoverySummary(selection, spend, quote, roi);
    const calendly = document.getElementById("cta-calendly") as HTMLAnchorElement;
    calendly.href = anySelection
      ? buildCalendlyUrl(brand.discoveryCallUrl, summary)
      : brand.discoveryCallUrl;
    calendly.dataset.summary = summary;

    // Sticky bar
    const sticky = document.getElementById("sticky-bar")!;
    sticky.hidden = !anySelection;
    document.getElementById("sticky-monthly")!.textContent = formatMoney(quote.monthlySubscription);

    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(selection));
    } catch {
      /* fine */
    }
  }

  // ---- events ----
  document.querySelectorAll<HTMLButtonElement>(".industry-chip").forEach((chip) => {
    chip.addEventListener("click", () => {
      const key = chip.dataset.industry!;
      selection.industryKey = selection.industryKey === key ? null : key;
      const industry = selection.industryKey ? getIndustry(selection.industryKey) : undefined;
      if (industry) {
        selection.employees = industry.defaultEmployees;
        selection.locations = industry.defaultLocations;
        for (const toolKey of industry.typicalStack) {
          if (!selection.tools[toolKey]) selection.tools[toolKey] = "keep";
        }
      }
      render();
    });
  });

  document.querySelectorAll<HTMLElement>(".tool-card").forEach((card) => {
    const key = card.dataset.tool!;
    card.querySelector(".tool-use")!.addEventListener("click", () => {
      selection.tools[key] = "keep";
      render();
    });
    card.querySelector('[data-action="keep"]')!.addEventListener("click", () => {
      selection.tools[key] = "keep";
      render();
    });
    card.querySelector('[data-action="replace"]')!.addEventListener("click", () => {
      selection.tools[key] = "replace" as ToolChoice;
      render();
    });
    card.querySelector('[data-action="remove"]')!.addEventListener("click", () => {
      delete selection.tools[key];
      render();
    });
  });

  for (const field of ["employees", "locations"] as const) {
    const input = document.getElementById(`${field}-input`) as HTMLInputElement;
    input.addEventListener("change", () => {
      const max = field === "employees" ? 500 : 50;
      selection[field] = Math.max(1, Math.min(max, Number(input.value) || 1));
      render();
    });
    document.querySelectorAll<HTMLButtonElement>(`[data-step="${field}"]`).forEach((btn) => {
      btn.addEventListener("click", () => {
        const max = field === "employees" ? 500 : 50;
        selection[field] = Math.max(1, Math.min(max, selection[field] + Number(btn.dataset.dir)));
        render();
      });
    });
  }

  document.getElementById("cta-copy")!.addEventListener("click", async () => {
    const summary = (document.getElementById("cta-calendly") as HTMLElement).dataset.summary ?? "";
    try {
      await navigator.clipboard.writeText(summary);
      document.getElementById("copy-confirm")!.hidden = false;
    } catch {
      /* clipboard blocked — nothing sensible to do */
    }
  });

  render();
</script>

<style>
  /* The hidden attribute must always win — several hidden-able elements
     below set display:flex, which would otherwise override it. */
  [hidden] {
    display: none !important;
  }

  section {
    padding: var(--space-3xl) 0 0;
  }

  .hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    padding-top: var(--space-2xl);
  }

  h1 {
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -1.5px;
    margin: 0;
  }

  .hero-sub {
    max-width: 560px;
    color: var(--text-secondary);
    font-size: 18px;
    line-height: 1.6;
    margin: 0;
  }

  .hero-note {
    color: var(--text-tertiary);
    font-size: 13px;
    margin: 0;
  }

  h2 {
    font-size: clamp(26px, 3.6vw, 36px);
    font-weight: 700;
    letter-spacing: -0.8px;
    margin: var(--space-sm) 0 var(--space-lg);
  }

  .step-label {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent-primary);
  }

  .step-sub {
    color: var(--text-secondary);
    max-width: 620px;
    line-height: 1.6;
    margin: calc(-1 * var(--space-md)) 0 var(--space-lg);
  }

  /* Industry */
  .industry-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .industry-chip {
    padding: 10px 18px;
    border-radius: 999px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-surface);
    color: var(--text-secondary);
    font: 500 14px var(--font-body);
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .industry-chip:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }

  .industry-chip.active {
    border-color: var(--accent-primary);
    background: var(--accent-primary-dim);
    color: var(--accent-primary-strong);
  }

  .size-row {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    flex-wrap: wrap;
  }

  .size-field label {
    display: block;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-bottom: var(--space-sm);
  }

  .stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    overflow: hidden;
  }

  .stepper button {
    width: 42px;
    height: 42px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-size: 18px;
    cursor: pointer;
  }

  .stepper button:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.04);
  }

  .stepper input {
    width: 64px;
    height: 42px;
    text-align: center;
    background: transparent;
    border: none;
    border-left: 1px solid var(--border-subtle);
    border-right: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font: 600 16px var(--font-body);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .stepper input::-webkit-outer-spin-button,
  .stepper input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  /* Tools */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  .tool-card {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    opacity: 0.72;
    transition: opacity 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .tool-card.in-use {
    opacity: 1;
    border-color: var(--border-strong);
  }

  .tool-card.will-replace {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 1px var(--accent-primary-dim);
  }

  .tool-head {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .tool-mark {
    width: 40px;
    height: 40px;
