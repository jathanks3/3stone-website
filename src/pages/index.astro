---
// src/pages/index.astro
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { brand, capabilities, processSteps, whyUs } from "../config/brand";

// Official icon mark (public/logo-mark.svg), inlined so it can be tinted and
// scaled purely with CSS for the subtle hero watermark below.
const brandMarkSvg = fs.readFileSync(path.resolve("public/logo-mark.svg"), "utf-8");

const PROCESS_ICONS: Record<string, string> = {
  Discovery: '<circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  Strategy: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1"/>',
  Architecture: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  Design: '<path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
  Development: '<polyline points="8 6 2 12 8 18"/><polyline points="16 6 22 12 16 18"/>',
  Testing: '<path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5Z"/><path d="m9 12 2 2 4-4"/>',
  Deployment: '<path d="M12 2c2 2 3 5 3 8 0 2-.5 4-1.5 5.5L12 22l-1.5-6.5C9.5 14 9 12 9 10c0-3 1-6 3-8Z"/><circle cx="12" cy="9" r="1.3"/>',
  "3Stone Care": '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>',
};
---

<BaseLayout title={brand.name} description={brand.description}>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-mark" aria-hidden="true" set:html={brandMarkSvg} />
      <h1>{brand.tagline}</h1>
      <p class="hero-sub">{brand.description}</p>
      <div class="hero-ctas">
        <Button href={brand.threeStoneOneUrl} variant="primary">Experience 3Stone One</Button>
        <Button href={brand.discoveryCallUrl} variant="secondary">Book Discovery Call</Button>
      </div>
    </div>
  </section>

  <!-- Flagship product: 3Stone One -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Flagship Product · Live Interactive Demo</span>
        <h2>Run every business you own from one platform.</h2>
      </div>
      <Card class="featured-project glass-accent">
        <div class="featured-project-grid">
          <img
            src="/images/3stone-one-screenshot.png"
            alt="3Stone One executive dashboard showing a morning briefing, a Business Health score, and revenue charts"
            class="featured-project-image"
            loading="lazy"
            width="1600"
            height="1000"
          />
          <div class="featured-project-body">
            <span class="portfolio-project-badge flagship-badge">Flagship Product</span>
            <p class="card-body featured-project-lead">
              One login. One dashboard. One AI. Switch between every business you own and watch the
              CRM, finance, projects, and team change with it - not just the labels. Keep the tools
              you already love, or replace them with a native module when you're ready.
            </p>
            <ul class="tech-tags">
              <li>Next.js</li>
              <li>TypeScript</li>
              <li>Recharts</li>
            </ul>
            <div class="featured-project-ctas">
              <Button href={brand.threeStoneOneUrl} variant="primary">Experience 3Stone One</Button>
              <Button href="/3stone-one" variant="ghost">Learn more →</Button>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section capabilities">
    <div class="container">
      <ul class="capability-list">
        {capabilities.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Trust -->
  <section class="section trust">
    <div class="container section-narrow">
      <span class="eyebrow">Business First. Technology Second.</span>
      <h2>We understand operations before we write a line of code.</h2>
      <p>
        Technology is simply the tool. Every engagement starts with how your
        business actually runs today - not with a list of features, and not
        with a pitch for the latest framework.
      </p>
    </div>
  </section>

  <!-- Problem we solve -->
  <section class="section">
    <div class="container section-narrow">
      <span class="eyebrow">The Problem</span>
      <h2>Most businesses don't need more software. They need better systems.</h2>
      <p>
        We've sat inside businesses during complex transformations and watched the
        same pattern play out: teams doing manual work that should be automated,
        data scattered across tools that don't talk to each other, and processes
        that only function because one person remembers all the exceptions.
      </p>
      <p>
        That's not a technology problem first - it's an operations problem that
        the right software can solve.
      </p>
      <ul class="symptom-list">
        <li>Repetitive manual work eating up hours every week</li>
        <li>Disconnected tools and spreadsheets standing in for real systems</li>
        <li>No single source of truth for what's actually happening in the business</li>
      </ul>
    </div>
  </section>

  <!-- How we work -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">How We Work</span>
        <h2>A process built for clarity, not surprises</h2>
      </div>
      <div class="process-list">
        {processSteps.map((item, idx) => (
          <div class="process-step">
            <div class="process-step-icon" set:html={`<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${PROCESS_ICONS[item.name] ?? ""}</svg>`} />
            <div class="process-step-body">
              <span class="process-step-number">{item.step}</span>
              <h3 class="card-title">{item.name}</h3>
              <p class="card-body">{item.detail}</p>
            </div>
            {idx < processSteps.length - 1 && <div class="process-connector" aria-hidden="true" />}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Innovation Lab: BetAI -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Innovation Lab</span>
        <h2>BetAI</h2>
      </div>
      <Card class="featured-project glass-accent">
        <div class="featured-project-grid">
          <img
            src="/images/betai-screenshot.png"
            alt="BetAI analysis result showing an overall rating, AI confidence, and biggest edge/risk callouts"
            class="featured-project-image"
            loading="lazy"
            width="1280"
            height="1488"
          />
          <div class="featured-project-body">
            <span class="portfolio-project-badge">Innovation Lab</span>
            <p class="card-body featured-project-lead">
              An AI-powered sports betting research platform - one of the experiments we build in the
              3Stone AI Innovation Lab to push our engineering and AI capabilities.
            </p>
            <ul class="tech-tags">
              <li>React</li>
              <li>TypeScript</li>
              <li>Vite</li>
            </ul>
            <div class="featured-project-ctas">
              <Button href={brand.betaiUrl} variant="primary">Live Demo</Button>
              <Button href={brand.githubUrl} variant="secondary">GitHub</Button>
              <Button href="/portfolio" variant="ghost">Full case study →</Button>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </section>

  <!-- Why 3Stone AI -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Why Clients Choose Us</span>
        <h2>What makes this different from a typical software agency</h2>
      </div>
      <div class="grid grid-3">
        {whyUs.map((item) => (
          <Card>
            <h3 class="card-title">{item.title}</h3>
            <p class="card-body">{item.detail}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Client stories placeholder -->
  <section class="section">
    <div class="container section-narrow">
      <span class="eyebrow">Client Success Stories</span>
      <h2>Coming soon</h2>
      <Card>
        <p class="card-body">
          3Stone AI is early. BetAI is our first public proof of how we design and
          build. Client case studies will appear here as engagements complete -
          we'd rather show real results later than invent them now.
        </p>
      </Card>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section final-cta">
    <div class="container section-narrow">
      <h2>Let's fix what's actually slowing your business down.</h2>
      <Button href={brand.discoveryCallUrl} variant="primary">Book Discovery Call</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
    overflow: hidden;
  }

  .hero-mark {
    position: absolute;
    top: 42%;
    left: 50%;
    z-index: -1;
    width: min(640px, 60vw);
    aspect-ratio: 200 / 150;
    transform: translate3d(-50%, -50%, 0);
    color: var(--text-primary);
    opacity: 0.035;
    pointer-events: none;
    animation: hero-mark-drift 50s ease-in-out infinite alternate;
  }

  .hero-mark :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  @keyframes hero-mark-drift {
    from {
      transform: translate3d(-50%, -50%, 0) scale(1);
    }
    to {
      transform: translate3d(-50%, -50%, 0) scale(1.03);
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 25% 20%, rgba(110, 147, 214, 0.16), transparent 45%),
      radial-gradient(circle at 78% 55%, rgba(110, 147, 214, 0.1), transparent 40%);
    animation: hero-drift 18s ease-in-out infinite alternate;
  }

  @keyframes hero-drift {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-2%, 2%, 0) scale(1.05);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg,
    .hero-mark {
      animation: none;
    }
  }

  .hero-inner {
    position: relative;
    isolation: isolate;
    max-width: 900px;
    margin: 0 auto;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1.2px;
    margin: 0 0 var(--space-lg);
  }

  .hero-sub {
    font-size: 19px;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto var(--space-xl);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .section {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border-subtle);
  }

  .capabilities {
    padding: var(--space-xl) 0;
  }

  .capability-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .capability-list li {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 10px 20px;
  }

  .trust {
    text-align: center;
  }

  .trust .eyebrow {
    color: var(--text-primary);
    font-size: 15px;
    letter-spacing: 0.5px;
    text-transform: none;
    font-weight: 700;
    font-family: var(--font-display);
  }

  .trust h2 {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  .trust p {
    max-width: 580px;
    margin: 0 auto;
  }

  .section-narrow {
    max-width: 720px;
  }

  .section-narrow h2 {
    text-align: left;
  }

  .trust.section .section-narrow,
  .trust .section-narrow {
    max-width: 640px;
  }

  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto var(--space-xl);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    letter-spacing: -0.8px;
    margin: var(--space-sm) 0 var(--space-md);
  }

  .section p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .symptom-list {
    margin-top: var(--space-lg);
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .symptom-list li {
    position: relative;
    padding-left: 26px;
    color: var(--text-secondary);
    font-size: 15px;
  }

  .symptom-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-primary);
  }

  .grid {
    display: grid;
    gap: var(--space-lg);
  }

  .grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid-3 {
      grid-template-columns: 1fr;
    }
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.2px;
    margin: 0 0 10px;
  }

  .card-body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Process - horizontal on desktop, connected by a thin line */
  .process-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg) var(--space-md);
  }

  .process-step {
    position: relative;
  }

  .process-step-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    color: var(--accent-primary);
    margin-bottom: var(--space-md);
  }

  .process-connector {
    display: none;
  }

  @media (min-width: 901px) {
    .process-connector {
      display: block;
      position: absolute;
      top: 20px;
      left: calc(50% + 32px);
      width: calc(100% - 40px);
      height: 1px;
      background: var(--border-subtle);
    }

    .process-step:nth-child(4) .process-connector {
      display: none;
    }
  }

  .process-step-number {
    display: block;
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-tertiary);
    margin-bottom: var(--space-xs);
    letter-spacing: 0.5px;
  }

  @media (max-width: 900px) {
    .process-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .process-list {
      grid-template-columns: 1fr;
    }
  }

  /* Featured project */
  .glass-accent {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .featured-project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (max-width: 800px) {
    .featured-project-grid {
      grid-template-columns: 1fr;
    }
  }

  .featured-project-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .featured-project-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .portfolio-project-badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--accent-primary);
    background: var(--accent-primary-dim);
    border: 1px solid rgba(110, 147, 214, 0.28);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .flagship-badge {
    color: var(--bg-base);
    background: var(--accent-primary);
    border-color: var(--accent-primary);
  }

  .featured-project-lead {
    font-size: 17px;
    color: var(--text-primary);
  }

  .tech-tags {
    display: flex;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tech-tags li {
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    padding: 5px 12px;
    border-radius: 999px;
  }

  .featured-project-ctas {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    align-items: center;
    margin-top: var(--space-sm);
  }

  .final-cta {
    text-align: center;
  }

  .final-cta .section-narrow {
    margin: 0 auto;
  }

  .final-cta h2 {
    text-align: center;
    margin-bottom: var(--space-xl);
  }
</style>
