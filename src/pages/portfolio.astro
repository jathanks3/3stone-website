---
// src/pages/portfolio.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { brand, futurePortfolio } from "../config/brand";

const features = [
  "Three workflows: Analyze My Bet, Find a Bet, Build My Parlay",
  "Overall rating, verdict, and AI confidence score",
  "Biggest edge and biggest risk called out visually",
  "Color-coded findings (positive / negative / neutral)",
  "Mock service layer designed to swap in real APIs without a UI rewrite",
];

const results = [
  "Fully designed, built, and deployed to production",
  "Demonstrates the complete discovery-to-deployment process used for client work",
  "A live, working product - not a mockup or a prototype",
];
---

<BaseLayout
  title="Portfolio"
  description="See BetAI, 3Stone AI's first portfolio product - an AI sports betting analyst that demonstrates how we design and build software."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">Portfolio</span>
      <h1>Proof, not promises</h1>
      <p>
        BetAI is our first live product - built the same way we build for
        clients: understand the problem, design a clean system, ship something
        real. Everything else here is coming as engagements complete.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <Card class="case-study">
        <span class="portfolio-project-badge">Portfolio Project</span>

        <div class="case-study-grid">
          <div class="case-study-screenshots">
            <img
              src="/images/betai-screenshot.png"
              alt="BetAI desktop view showing an overall rating, Bet verdict, AI confidence score, and biggest edge/risk callouts"
              class="case-study-image desktop-shot"
              loading="lazy"
              width="1280"
              height="1488"
            />
            <img
              src="/images/betai-screenshot-mobile.png"
              alt="BetAI mobile view showing the same analysis, responsive to phone screens"
              class="case-study-image mobile-shot"
              loading="lazy"
              width="668"
              height="1280"
            />
          </div>

          <div class="case-study-body">
            <h2 class="card-title">BetAI</h2>
            <p class="card-body">
              An AI sports betting analyst - not a chatbot. It rates a bet, gives
              a clear verdict (Bet / Lean / Pass / Avoid), and explains exactly
              why with a leg-by-leg breakdown.
            </p>

            <div class="case-study-block">
              <span class="block-label">The Problem</span>
              <p class="card-body">
                Bettors get flooded with opinions and no structured way to
                evaluate a bet. BetAI turns scattered signals - injuries, form,
                line movement - into one clear, explained recommendation.
              </p>
            </div>

            <div class="case-study-block">
              <span class="block-label">The Solution</span>
              <p class="card-body">
                A unified analysis engine powers all three workflows - Analyze
                My Bet, Find a Bet, Build My Parlay - so every recommendation
                is scored and explained the same consistent way, no matter how
                the user starts.
              </p>
            </div>

            <div class="case-study-block">
              <span class="block-label">Architecture</span>
              <p class="card-body">
                One shared data model (Finding, BetLeg, BetSlipAnalysis) and a
                single service layer sit behind all three workflows. The mock
                service implements a stable interface, so a real sports-data
                and AI backend can be swapped in later without touching the
                UI.
              </p>
            </div>

            <div class="case-study-block">
              <span class="block-label">Technologies</span>
              <ul class="tech-tags">
                <li>React</li>
                <li>TypeScript</li>
                <li>Vite</li>
                <li>Service-layer architecture</li>
              </ul>
            </div>

            <div class="case-study-ctas">
              <Button href={brand.betaiUrl} variant="primary">Live Demo</Button>
              <Button href={brand.githubUrl} variant="secondary">GitHub</Button>
            </div>
          </div>
        </div>

        <div class="case-study-extra">
          <div class="case-study-block">
            <span class="block-label">Features</span>
            <ul class="check-list">
              {features.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="case-study-block">
            <span class="block-label">Results</span>
            <ul class="check-list">
              {results.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </Card>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Future Portfolio</span>
        <h2>More products, coming soon</h2>
      </div>
      <div class="grid grid-3">
        {futurePortfolio.map((item) => (
          <Card class="coming-soon-card">
            <span class="coming-soon-badge">Coming Soon</span>
            <h3 class="card-title">{item.name}</h3>
            <p class="card-body">{item.detail}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -1.2px;
    margin: 0 0 var(--space-lg);
  }

  .page-hero p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 620px;
  }

  .section {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-header {
    text-align: center;
    margin: 0 auto var(--space-xl);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 32px);
    font-weight: 700;
    letter-spacing: -0.6px;
    margin: 0;
  }

  .portfolio-project-badge {
    display: inline-block;
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--accent-primary);
    background: var(--accent-primary-dim);
    border: 1px solid rgba(110, 147, 214, 0.28);
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: var(--space-lg);
  }

  .case-study-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (max-width: 800px) {
    .case-study-grid {
      grid-template-columns: 1fr;
    }
  }

  .case-study-screenshots {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .case-study-image {
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .desktop-shot {
    width: 68%;
    height: auto;
  }

  .mobile-shot {
    width: 32%;
    height: auto;
  }

  @media (max-width: 500px) {
    .case-study-screenshots {
      flex-direction: column;
    }

    .desktop-shot,
    .mobile-shot {
      width: 100%;
    }
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.4px;
    margin: 0 0 var(--space-sm);
  }

  .card-body {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .case-study-block {
    margin-top: var(--space-lg);
  }

  .block-label {
    display: block;
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    margin-bottom: 8px;
  }

  .tech-tags {
    display: flex;
    gap: 8px;
    list-style: none;
    margin: var(--space-sm) 0 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tech-tags li {
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    padding: 5px 12px;
    border-radius: 999px;
  }

  .case-study-ctas {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .case-study-extra {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border-subtle);
  }

  @media (max-width: 600px) {
    .case-study-extra {
      grid-template-columns: 1fr;
    }
  }

  .case-study-extra .case-study-block {
    margin-top: 0;
  }

  .check-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .check-list li {
    position: relative;
    padding-left: 24px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  .check-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 7px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-primary);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .coming-soon-card {
    opacity: 0.6;
  }

  .coming-soon-badge {
    display: inline-block;
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--text-secondary);
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    padding: 4px 10px;
    border-radius: 999px;
    margin-bottom: var(--space-sm);
  }
</style>
