---
// src/pages/about.astro
import Card from "../components/Card.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { values } from "../config/brand";

// Icons ordered to match `values` from brand.ts:
// Solve the real problem, Build reusable systems, Simplicity beats
// complexity, Never overpromise, Every project strengthens the company.
const VALUE_ICONS = [
  '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1"/>',
  '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  '<rect x="5" y="5" width="14" height="14" rx="3"/>',
  '<path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5Z"/><path d="m9 12 2 2 4-4"/>',
  '<polyline points="3 17 9 11 13 15 21 7"/><polyline points="14 7 21 7 21 14"/>',
];
---

<BaseLayout
  title="About"
  description="3Stone AI was founded by Jathan Spaulding to combine business strategy with modern software development."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">About</span>
      <h1>Businesses don't need more software. They need better systems.</h1>
    </div>
  </section>

  <section class="section">
    <div class="container section-narrow">
      <span class="block-label">Founder</span>
      <h2>Jathan Spaulding</h2>
      <p>
        Jathan Spaulding founded 3Stone AI with one goal: help businesses solve
        expensive operational problems through custom software and intelligent
        automation.
      </p>
      <p>
        After graduating Cum Laude from Morehouse College with a degree in
        Business Administration, Jathan began his career in Strategy &
        Transactions (M&A), where he worked on complex business
        transformations, operational planning, and cross-functional projects.
        That experience taught him that many companies don't need more
        employees. They need better systems.
      </p>
      <p>
        Rather than building technology for its own sake, Jathan focuses on
        understanding how businesses operate, identifying inefficient
        processes, and designing software that saves time, reduces manual
        work, and creates measurable value.
      </p>
      <p>
        3Stone AI combines business strategy with modern software development
        to build customer portals, AI assistants, internal dashboards,
        workflow automation, and custom business applications tailored to each
        client's needs.
      </p>
      <p>
        The company's first product, BetAI, serves as both a portfolio project
        and a demonstration of the reusable systems, design patterns, and
        development process that power future client work.
      </p>
      <p>
        Jathan's long-term vision is to build a software company that creates
        lasting value for clients while developing scalable products that
        generate recurring revenue.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="block-label">Values</span>
        <h2>What we hold ourselves to</h2>
      </div>
      <div class="grid grid-5">
        {values.map((value, idx) => (
          <Card class="value-card">
            <div
              class="value-icon"
              set:html={`<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${VALUE_ICONS[idx] ?? ""}</svg>`}
            />
            <p>{value}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1.2px;
    margin: 0;
  }

  .section {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-narrow {
    max-width: 680px;
  }

  .section-header {
    text-align: center;
    margin: 0 auto var(--space-xl);
  }

  .block-label {
    display: block;
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: var(--space-sm);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 32px);
    font-weight: 700;
    letter-spacing: -0.6px;
    margin: 0 0 var(--space-lg);
  }

  .section-header h2 {
    margin: 0;
  }

  .section p {
    font-size: 17px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin: 0 0 var(--space-md);
  }

  .grid {
    display: grid;
    gap: var(--space-md);
  }

  .grid-5 {
    grid-template-columns: repeat(5, 1fr);
  }

  @media (max-width: 900px) {
    .grid-5 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid-5 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .value-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-align: center;
    align-items: center;
  }

  .value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    color: var(--accent-primary);
  }

  .value-card p {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-primary);
  }
</style>
