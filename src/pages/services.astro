---
// src/pages/services.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { brand, services } from "../config/brand";
---

<BaseLayout
  title="Services"
  description="What 3Stone AI builds: customer portals, dashboards, workflow automation, AI assistants, and custom software focused on business outcomes."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">SERVICES</span>
      <h1>Software built around business value, not technology for its own sake</h1>
      <p>
        Every service below solves a specific, common operational problem. We
        scope engagements around the outcome you need - fewer manual hours, one
        source of truth, a system your team actually uses - not a fixed menu of
        features.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((service) => (
          <Card>
            <h2 class="card-title">{service.name}</h2>
            <p class="card-body">{service.summary}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container section-narrow">
      <h2>Not sure which of these fits your business?</h2>
      <p>That's exactly what a discovery call is for.</p>
      <Button href={brand.discoveryCallUrl} variant="primary">Book a Discovery Call</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-2xl) 0;
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.6px;
    color: var(--accent-primary);
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.8px;
    margin: 0 0 var(--space-md);
  }

  .page-hero p,
  .final-cta p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 620px;
  }

  .section {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-narrow {
    max-width: 720px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .card-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .final-cta {
    text-align: center;
  }

  .final-cta .section-narrow {
    margin: 0 auto;
  }

  .final-cta h2 {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 var(--space-sm);
  }

  .final-cta p {
    margin: 0 auto var(--space-lg);
    text-align: center;
  }
</style>
