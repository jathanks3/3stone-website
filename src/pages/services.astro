---
// src/pages/services.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { brand, services, pricingTiers, faqs } from "../config/brand";
---

<BaseLayout
  title="Services"
  description="What 3Stone AI builds: customer portals, dashboards, workflow automation, AI assistants, and custom software focused on business outcomes."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">Services</span>
      <h1>Software built around business value, not technology for its own sake</h1>
      <p>
        Every service below solves a specific, common operational problem. We
        scope engagements around the outcome you need - fewer manual hours, one
        source of truth, a system your team actually uses - not a fixed menu of
        features.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((service) => (
          <Card class="service-card">
            <h2 class="card-title">{service.name}</h2>
            <div class="service-row">
              <span class="service-label">Problem</span>
              <p class="card-body">{service.problem}</p>
            </div>
            <div class="service-row">
              <span class="service-label">Solution</span>
              <p class="card-body">{service.solution}</p>
            </div>
            <div class="service-row">
              <span class="service-label">Outcome</span>
              <p class="card-body service-outcome">{service.outcome}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section">
    <div class="container section-narrow">
      <span class="eyebrow">Investment</span>
      <h2>Every project is custom.</h2>
      <p>
        We don't sell fixed packages, because no two businesses have the same
        problem. Here's a general sense of typical project investments so
        you're not walking in blind.
      </p>
    </div>
    <div class="container">
      <h3 class="pricing-heading">Typical Project Investments</h3>
      <div class="grid grid-4">
        {pricingTiers.map((tier) => (
          <Card class="pricing-card">
            <h3 class="card-title">{tier.name}</h3>
            <p class="pricing-price">{tier.price}</p>
          </Card>
        ))}
      </div>
      <p class="pricing-disclaimer">
        Every proposal is scoped and quoted individually after a discovery call
        - these are starting points, not quotes.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container section-narrow">
      <span class="eyebrow">FAQ</span>
      <h2>Common questions</h2>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container section-narrow">
      <h2>Not sure which of these fits your business?</h2>
      <p>That's exactly what a discovery call is for.</p>
      <Button href={brand.discoveryCallUrl} variant="primary">Book Discovery Call</Button>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -1.2px;
    margin: 0 0 var(--space-lg);
  }

  .page-hero p,
  .final-cta p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 620px;
  }

  .section {
    padding: var(--space-xl) 0 var(--space-2xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-narrow {
    max-width: 720px;
  }

  .section-narrow h2 {
    margin-top: var(--space-sm);
  }

  .section-narrow > p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 var(--space-xl);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  @media (max-width: 900px) {
    .grid,
    .grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid,
    .grid-4 {
      grid-template-columns: 1fr;
    }
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.2px;
    margin: 0 0 var(--space-md);
  }

  .card-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .service-row {
    margin-bottom: var(--space-md);
  }

  .service-row:last-child {
    margin-bottom: 0;
  }

  .service-label {
    display: block;
    font-family: var(--font-label);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 4px;
  }

  .service-outcome {
    color: var(--text-primary);
  }

  /* Pricing */
  .pricing-heading {
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-tertiary);
    text-align: center;
    margin: 0 0 var(--space-lg);
  }

  .pricing-card {
    text-align: center;
  }

  .pricing-price {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--accent-primary);
    margin: 0;
  }

  .pricing-disclaimer {
    text-align: center;
    font-size: 13px;
    color: var(--text-tertiary);
    margin: var(--space-lg) 0 0;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .faq-item {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
  }

  .faq-item summary {
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 20px;
    font-weight: 400;
    color: var(--text-tertiary);
    margin-left: var(--space-md);
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: var(--space-md) 0 0;
  }

  .final-cta {
    text-align: center;
  }

  .final-cta .section-narrow {
    margin: 0 auto;
  }

  .final-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 30px);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin: 0 0 var(--space-sm);
  }

  .final-cta p {
    margin: 0 auto var(--space-xl);
    text-align: center;
  }
</style>
