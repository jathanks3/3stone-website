---
// src/pages/contact.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import { brand } from "../config/brand";
---

<BaseLayout
  title="Contact"
  description="Get in touch with 3Stone AI to talk about a custom software project or book a discovery call."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about what's slowing your business down.</h1>
      <p>
        Tell us a bit about the problem you're trying to solve. No sales
        pitch on the first call - just a conversation about whether custom
        software actually makes sense for you.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <Card class="contact-form-card">
        <form
          method="POST"
          action={`mailto:${brand.contactEmail}`}
          enctype="text/plain"
          class="contact-form"
        >
          <div class="form-row">
            <div class="form-field">
              <label for="name">Name</label>
              <input type="text" id="name" name="Name" required />
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input type="email" id="email" name="Email" required />
            </div>
          </div>
          <div class="form-field">
            <label for="company">Company</label>
            <input type="text" id="company" name="Company" />
          </div>
          <div class="form-field">
            <label for="message">What are you trying to solve?</label>
            <textarea id="message" name="Message" rows="6" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Request a Discovery Call</button>
          <p class="form-note">
            This opens your email client with the message pre-filled. Prefer to
            email directly? Reach us at{" "}
            <a href={`mailto:${brand.contactEmail}`}>{brand.contactEmail}</a>.
          </p>
        </form>
      </Card>

      <div class="contact-sidebar">
        <Card class="contact-sidebar-card">
          <span class="block-label">Book Discovery Call</span>
          <p class="sidebar-text">
            Direct scheduling is coming soon (Calendly integration). For now,
            use the form or email us directly and we'll set up a time.
          </p>
        </Card>

        <div class="contact-direct">
          <div class="contact-direct-item">
            <span class="block-label">Email</span>
            <a href={`mailto:${brand.contactEmail}`}>{brand.contactEmail}</a>
          </div>
          <div class="contact-direct-item">
            <span class="block-label">LinkedIn</span>
            <a href={brand.linkedinUrl} target="_blank" rel="noopener noreferrer">
              3Stone AI on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1.2px;
    margin: 0 0 var(--space-lg);
  }

  .page-hero p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 560px;
  }

  .section {
    padding: var(--space-xl) 0 var(--space-3xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-narrow {
    max-width: 680px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  @media (max-width: 500px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-field label {
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }

  .form-field input,
  .form-field textarea {
    padding: 13px 16px;
    background: var(--bg-surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 15px;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px var(--accent-primary-dim);
  }

  .btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    padding: 15px 28px;
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    background: var(--text-primary);
    color: var(--bg-base);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
    background: #ffffff;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .form-note {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.6;
    margin: 0;
  }

  .form-note a {
    color: var(--accent-primary);
  }

  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .sidebar-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: var(--space-sm) 0 0;
  }

  .contact-direct {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
  }

  .contact-direct-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .block-label {
    font-family: var(--font-label);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .contact-direct-item a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 15px;
  }

  .contact-direct-item a:hover {
    color: var(--accent-primary);
  }
</style>
