---
// src/pages/terms.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { brand } from "../config/brand";
---

<BaseLayout
  title="Terms of Service"
  description="Terms for using the 3Stone AI website."
>
  <section class="page-hero">
    <div class="container section-narrow">
      <span class="eyebrow">Terms of Service</span>
      <h1>The basics of using this website</h1>
      <p>Last updated: {new Date().toLocaleDateString("en-US", { year: "numeric", month: "long" })}</p>
    </div>
  </section>

  <section class="section">
    <div class="container section-narrow">
      <h2>About this site</h2>
      <p>
        This website is informational - it describes 3Stone AI, its
        services, and its portfolio. By using it, you agree to these terms.
      </p>

      <h2>No warranty</h2>
      <p>
        This site is provided as-is. We work to keep it accurate and
        available, but we don't guarantee it will be error-free or
        uninterrupted.
      </p>

      <h2>Client engagements</h2>
      <p>
        Nothing on this website constitutes a contract or service agreement.
        Actual project work, pricing, and deliverables are governed by a
        separate, signed agreement negotiated directly between 3Stone AI and
        the client.
      </p>

      <h2>Intellectual property</h2>
      <p>
        The content, design, and branding on this site belong to 3Stone AI.
        BetAI, shown in the Portfolio section, is our own project and is
        credited accordingly.
      </p>

      <h2>Changes</h2>
      <p>
        We may update these terms as the site and business evolve. Continued
        use of the site after a change means you accept the update.
      </p>

      <h2>Questions</h2>
      <p>
        Contact us at{" "}
        <a href={`mailto:${brand.contactEmail}`}>{brand.contactEmail}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
  }

  .page-hero .eyebrow {
    display: block;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.5vw, 44px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
    margin: 0 0 var(--space-md);
  }

  .page-hero p {
    font-size: 14px;
    color: var(--text-tertiary);
  }

  .section {
    padding: var(--space-xl) 0 var(--space-3xl);
    border-top: 1px solid var(--border-subtle);
  }

  .section-narrow {
    max-width: 680px;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    margin: var(--space-xl) 0 var(--space-sm);
  }

  h2:first-of-type {
    margin-top: 0;
  }

  .section p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 var(--space-md);
  }

  .section a {
    color: var(--accent-primary);
  }
</style>
